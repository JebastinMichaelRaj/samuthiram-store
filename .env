# ===== SERVER CONFIG =====
PORT=3000

# ===== DATABASE =====
# Local (development):
MONGODB_URI=mongodb://localhost:27017/samuthiram_store

# Production (MongoDB Atlas) - uncomment and fill in:
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.8v1fq6n.mongodb.net/samuthiram_store?retryWrites=true&w=majority

# ===== SESSION SECURITY =====
# Change this to a long random string in production!
SESSION_SECRET=samuthiram-super-secret-session-key-2025

# ===== ADMIN CREDENTIALS =====
# Default login: admin / samuthiram123 (used if ADMIN_PASSWORD_HASH is not set)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=samuthiram123

# Production: generate a bcrypt hash by POSTing to /api/admin/generate-hash
# with body {"password":"yournewpassword"} then paste the hash here:
# ADMIN_PASSWORD_HASH=$2b$10$examplehashgoeshere...
